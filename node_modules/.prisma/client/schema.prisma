generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ConnectorTaskType {
  BOOKING_CREATE
  FILE_TRANSFER
  GENERATE_RDP
  STATUS_UPDATE
}

enum ConnectorTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  resetToken    String?
  resetTokenExp DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
  projects      Project[]
}

model Hardware {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  vmTemplate  String?
  meshNodeId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]
  projects    Project[]

  @@index([isActive])
}

model Booking {
  id         String        @id @default(cuid())
  title      String
  labName    String
  start      DateTime
  end        DateTime
  duration   Int
  userId     String
  hardwareId String?
  status     BookingStatus @default(CONFIRMED)
  rdpLink    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  hardware   Hardware?     @relation(fields: [hardwareId], references: [id], onDelete: SetNull)
  logs       Log[]

  @@index([userId, start])
  @@index([labName, start, end])
}

model Project {
  id             String        @id @default(cuid())
  projectName    String
  controls       String[]
  sensors        String?
  expectedOutput String?
  platform       String?
  userId         String?
  hardwareId     String?
  bookingId      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  hardware       Hardware?     @relation(fields: [hardwareId], references: [id], onDelete: SetNull)
  files          ProjectFile[]
}

model ProjectFile {
  id           String   @id @default(cuid())
  projectId    String
  originalName String
  storagePath  String
  contentType  String?
  sizeBytes    Int
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ConnectorTask {
  id          String              @id @default(cuid())
  type        ConnectorTaskType
  status      ConnectorTaskStatus @default(PENDING)
  payload     Json
  result      Json?
  assignedTo  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  completedAt DateTime?

  @@index([status, createdAt])
}

model VmStatus {
  id         String   @id @default(cuid())
  vmId       String
  hardwareId String?
  bookingId  String?
  state      String
  rdpLink    String?
  metadata   Json?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([vmId])
  @@index([bookingId])
}

model Log {
  id        String   @id @default(cuid())
  bookingId String?
  level     String   @default("info")
  message   String
  source    String   @default("backend")
  createdAt DateTime @default(now())
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([bookingId, createdAt])
}
